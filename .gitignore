# --- AltiOS UAV .gitignore ---

# OS Metadata
.DS_Store
Thumbs.db
*.swp
*~

# IDE / Project Files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace
.history/

# Arduino Build Artifacts
# These are generated by the Arduino IDE/CLI during compilation
build/
bin/
out/
*.hex
*.elf
*.o
*.lst
*.map
*.d
*.a

# C++ Build Artifacts
*.obj
*.exe
*.pdb
*.ilk
*.log
*.tlog
*.lastbuildstate
*.idb

# Libraries (if managed by PM)
# libraries/

# External Tools
node_modules/
dist/
